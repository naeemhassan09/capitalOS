# ---------------------------------------------------------------------------
# CapitalOS environment configuration.
# Copy to `.env` and fill in real values. NEVER commit your real .env.
# Generate secrets:
#   SECRET_KEY:     python -c "import secrets; print(secrets.token_urlsafe(48))"
#   ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ---------------------------------------------------------------------------

# --- App ---
APP_ENV=development
APP_NAME=CapitalOS
APP_URL=http://localhost:5173
DOMAIN=localhost
LOG_LEVEL=INFO

# --- Secrets (REQUIRED in production; app refuses to boot with placeholders) ---
SECRET_KEY=change-me
ENCRYPTION_KEY=

# --- Database ---
POSTGRES_DB=capitalos
POSTGRES_USER=capitalos
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional full override; if empty it is assembled from the POSTGRES_* values.
DATABASE_URL=

# --- Redis (reserved for future background jobs; unused in the core build) ---
REDIS_URL=

# --- Sessions / auth ---
SESSION_COOKIE_NAME=capitalos_session
SESSION_MAX_AGE=1209600
SESSION_COOKIE_SECURE=false
TOTP_ISSUER=CapitalOS
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECONDS=300

# --- CORS / hosts ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUSTED_HOSTS=*

# --- Uploads / imports ---
MAX_UPLOAD_SIZE_MB=10
FILE_ENCRYPTION_ENABLED=true
UPLOAD_DIR=/app/var/uploads

# --- Backups (documented; scripts provided, not wired into core build) ---
BACKUP_RETENTION_DAYS=30
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_ENCRYPTION_PASSPHRASE=

# --- Open Banking (feature-flagged OFF) ---
OPEN_BANKING_ENABLED=false
GOCARDLESS_BANK_DATA_SECRET_ID=
GOCARDLESS_BANK_DATA_SECRET_KEY=

# --- Observability ---
SENTRY_DSN=
