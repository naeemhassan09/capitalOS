# CapitalOS backup configuration.
# Copy to deploy/backup.env on the server (this file stays out of git).

# --- Which database to dump ---
# Multi-site host: dump the shared edge Postgres using its superuser.
COMPOSE_FILE=/opt/capitalos/deploy/edge/docker-compose.yml
PG_SERVICE=postgres
POSTGRES_DB=capitalos
POSTGRES_USER=capitaladmin
BACKUP_DIR=/opt/capitalos/backups

# --- Encryption (REQUIRED before any off-site upload) ---
# Generate once, then STORE IT SOMEWHERE SAFE OFF THE SERVER (password manager).
# Losing it makes every encrypted backup unrecoverable.
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BACKUP_ENCRYPTION_PASSPHRASE=

# --- Off-site upload (Google Drive via rclone) ---
# Leave RCLONE_DEST empty to keep backups local-only.
# Configure an rclone remote named 'gdrive' whose root is your Drive folder,
# then uploads land in a "CapitalOS" subfolder there.
RCLONE_DEST=gdrive:CapitalOS
RCLONE_RETENTION_DAYS=90
