# Edge stack secrets. Copy to deploy/edge/.env on the server and fill in.
#   cp deploy/edge/.env.example deploy/edge/.env

# Email used by Let's Encrypt for expiry notices.
ACME_EMAIL=you@example.com

# The domain CapitalOS is served on (kept out of the repo; Caddy reads it).
CAPITALOS_DOMAIN=your-domain.example

# Shared Postgres superuser (used only to create per-site databases/roles).
POSTGRES_SUPERUSER=capitaladmin
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_SUPERUSER_PASSWORD=change-me-strong
