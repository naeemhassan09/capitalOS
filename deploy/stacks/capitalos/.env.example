# CapitalOS production env for the multi-site host.
# Copy to deploy/stacks/capitalos/.env on the server and fill in.
#   SECRET_KEY:     python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   ENCRYPTION_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   DB password:    the one you set when running deploy/scripts/provision-db.sh capitalos

APP_ENV=production
APP_NAME=CapitalOS
APP_URL=https://your-domain.example
DOMAIN=your-domain.example
LOG_LEVEL=INFO

SECRET_KEY=change-me
ENCRYPTION_KEY=

# Shared Postgres (host "shared-postgres" on the private dbnet network).
DATABASE_URL=postgresql+psycopg2://capitalos:CHANGE_ME_DB_PASSWORD@shared-postgres:5432/capitalos

# Security / cookies (HTTPS in production)
SESSION_COOKIE_NAME=capitalos_session
SESSION_MAX_AGE=1209600
SESSION_COOKIE_SECURE=true
TOTP_ISSUER=CapitalOS

# CORS is same-origin behind Caddy, but set explicitly for safety.
CORS_ALLOWED_ORIGINS=https://your-domain.example
TRUSTED_HOSTS=your-domain.example

MAX_UPLOAD_SIZE_MB=10
FILE_ENCRYPTION_ENABLED=true
UPLOAD_DIR=/app/var/uploads

OPEN_BANKING_ENABLED=false
